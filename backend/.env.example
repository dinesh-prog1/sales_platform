PORT=8080
ENVIRONMENT=development
APP_BASE_URL=http://localhost:3000
JWT_SECRET=change-this
ADMIN_API_TOKEN=change-this-admin-token
CORS_ALLOWED_ORIGINS=http://localhost:3000
DATABASE_URL=postgres://postgres:password@localhost:5432/aisales?sslmode=disable
REDIS_URL=redis://:aisales_redis_secret@localhost:6379/0
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AI Sales Platform <noreply@example.com>
SCHEDULING_LINK=https://calendly.com/your-link

# ── Google Calendar / Meet integration (optional) ─────────────────────────────
# Without these, the system generates a valid-format Meet code as a placeholder.
# To enable real Meet links:
#  1. Go to console.cloud.google.com → New Project → Enable "Google Calendar API"
#  2. Create a Service Account → Keys → Add Key → JSON  → download key file
#  3. Share YOUR Google Calendar with the service account email (Editor permission)
#  4. Paste the full JSON content (single line) in GOOGLE_SERVICE_ACCOUNT_JSON
#  5. Set GOOGLE_CALENDAR_ID to your Gmail address
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CALENDAR_ID=
